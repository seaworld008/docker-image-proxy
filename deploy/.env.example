# Required: stable random secret used by the registry HTTP layer.
# Generate on the server with:
#   openssl rand -hex 32
REGISTRY_HTTP_SECRET=replace-with-64-hex-chars

# Default is local-only to avoid exposing an unauthenticated mirror publicly.
# For a controlled LAN or a fronting gateway on the same host, keep 127.0.0.1.
# To expose directly, set PROXY_BIND_ADDR=0.0.0.0 and protect the port first.
PROXY_BIND_ADDR=127.0.0.1
PROXY_HTTP_PORT=5000

# Optional: enable with docker-compose.with-auth.yml.
# Use a dedicated low-privilege Docker Hub account/token. Do not use a personal
# account that can access private images unless the mirror is access-controlled.
REGISTRY_PROXY_USERNAME=
REGISTRY_PROXY_PASSWORD=
