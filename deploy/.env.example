# 必填：Registry HTTP 层使用的稳定随机密钥。
# 在服务器上生成：
#   openssl rand -hex 32
REGISTRY_HTTP_SECRET=replace-with-64-hex-chars

# 默认仅监听本机，避免未鉴权的 mirror 直接暴露到公网。
# 如果前置网关/CDN 与本服务在同一台机器，建议保持 127.0.0.1。
# 如需直接暴露端口，必须先配置云安全组或防火墙白名单，再改成 0.0.0.0。
PROXY_BIND_ADDR=127.0.0.1
PROXY_HTTP_PORT=5000

# 必填：Docker Hub 上游认证账号和 Access Token。
# 生产自建 mirror 必须配置，避免匿名拉取触发 Docker Hub 限流。
# 建议使用专用低权限 Docker Hub 账号/token；如果账号可访问私有镜像，
# 必须先给 mirror 做访问控制，否则该账号可访问的私有资源可能被 mirror 使用者拉取。
REGISTRY_PROXY_USERNAME=
REGISTRY_PROXY_PASSWORD=
